{
  "name": "upgradr",
  "version": "0.2.0",
  "description": "Self-update for Bun CLIs: check npm for a newer release, then upgrade in place via npm/bun or a GitHub release binary.",
  "type": "module",
  "license": "MIT",
  "author": "Evan Tahler",
  "keywords": [
    "cli",
    "self-update",
    "auto-update",
    "upgrade",
    "bun",
    "semver",
    "npm",
    "github-releases"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/evantahler/upgradr.git"
  },
  "homepage": "https://github.com/evantahler/upgradr#readme",
  "bugs": {
    "url": "https://github.com/evantahler/upgradr/issues"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["src", "README.md", "LICENSE"],
  "scripts": {
    "test": "bun test",
    "lint": "tsc --noEmit && biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "ansis": "^4.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
