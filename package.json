{
  "name": "upgradr",
  "version": "0.3.0",
  "description": "Self-update for Bun & Node CLIs: check npm for a newer release, then upgrade in place via npm/bun or a GitHub release binary.",
  "type": "module",
  "license": "MIT",
  "author": "Evan Tahler",
  "keywords": [
    "cli",
    "self-update",
    "auto-update",
    "upgrade",
    "bun",
    "semver",
    "npm",
    "github-releases"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/evantahler/upgradr.git"
  },
  "homepage": "https://github.com/evantahler/upgradr#readme",
  "bugs": {
    "url": "https://github.com/evantahler/upgradr/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "scripts": {
    "test": "bun test",
    "lint": "tsc --noEmit && biome check .",
    "format": "biome check --write .",
    "build": "tsc -p tsconfig.build.json",
    "smoke": "node scripts/node-smoke.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ansis": "^4.3.1",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "@types/semver": "^7.7.1",
    "typescript": "^6.0.3"
  }
}
